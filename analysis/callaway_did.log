. cap program drop _es_export_with_plot

. program define _es_export_with_plot
  1.     version 18.0
  2.     syntax , DV(string) TITLE(string) OUTDOC(string) [PRE(integer 3) POSTSHORT(integer 4) POSTLONG(integer 6)]
  3. 
.     * Clean title to avoid non-ASCII (remove Unicode escapes)
.     local clean_title = subinstr("`title'", "", "-", .)
  4. 
.     * Run csdid
.     quietly csdid `dv', ivar(est_id) time(year) gvar(first_hit) notyet vce(cluster est_id)
  5.     estimates store es
  6. 
.     * Event study plotting
.     quietly estat event, window(-`pre' `postlong')
  7.     
.     preserve
  8.         * PNG path
.         local outpng = subinstr("`outdoc'","results/tables/","results/plots/",.)
  9.         local outpng = subinstr("`outpng'",".docx",".png",.)
 10. 
.         csdid_plot, xtitle("Event time (years)") ytitle("ATT") title("`clean_title'")
 11.         graph export "`outpng'", replace width(2000)
 12. 
.         * DOCX export
.         putdocx clear
 13.         putdocx begin, pagesize(letter) font("Arial",10)
 14.         putdocx paragraph, style(Heading1)
 15.         putdocx text ("`title'")
 16.         putdocx paragraph, style(Heading2)
 17.         
.         quietly estat event, window(-`pre' `postlong')
 18.         putdocx text ("Event-time dynamics (-`pre'..`postlong')")
 19.         matrix table_transposed = r(table)'
 20.         putdocx table t1 = matrix(table_transposed), rownames colnames nformat("$NUMFMT")
 21.         putdocx paragraph, style(Heading2)
 22.         putdocx text ("Aggregated effects (coefficients only)")
 23.         
.         quietly estat event, window(-`pre' -1)
 24.         putdocx paragraph
 25.         putdocx text ("Pre_avg (-`pre'..-1)  = " + strofreal(r(table)[1,1], "$NUMFMT"))
 26.         
.         quietly estat event, window(0 `postshort')
 27.         putdocx paragraph
 28.         putdocx text ("Post_avg (0..`postshort') = " + strofreal(r(table)[1,2], "$NUMFMT"))
 29.         
.         quietly estat event, window(0 `postlong')
 30.         putdocx paragraph
 31.         putdocx text ("Post_avg (0..`postlong') = " + strofreal(r(table)[1,2], "$NUMFMT"))
 32.         
.         * Wald tests
.         putdocx paragraph, style(Heading2)
 33.         putdocx text ("Wald Tests")
 34.         
.         putdocx paragraph
 35.         putdocx text ("H0: all pre-treatment coefficients are equal to zero (-3 -1)")
 36.         putdocx paragraph
 37.         * Pre-treatment tests (-3 -1)
.         estimates restore es
 38.         cap quietly estat event, window(-3 -1) post
 39.         if _rc == 0{
 40.                 local coefnames : colnames e(b)
 41.                 local tst ""
 42.                 foreach c of local coefnames {
 43.                         if strpos("`c'", "Tm"){
 44.                                 local tst "`tst' (`c'=0)"
 45.                         }
 46.                     }
 47.                 test `tst'
 48.                 putdocx table preWald = (3, 2)
 49.                 putdocx table preWald(1,1) = ("chi2"), bold
 50.                 putdocx table preWald(1,2) = (strofreal(r(chi2), "$NUMFMT"))
 51.                 putdocx table preWald(2,1) = ("df"), bold
 52.                 putdocx table preWald(2,2) = (string(r(df)))
 53.                 putdocx table preWald(3,1) = ("p"), bold
 54.                 putdocx table preWald(3,2) = (strofreal(r(p), "$NUMFMT"))
 55.         } 
 56.         else {
 57.                 putdocx text ("Test failed, missing/incomplete coefficients for window (-3 -1)")
 58.         }
 59.         
.         putdocx paragraph
 60.         putdocx text ("H0: all short-run post-treatment coefficients are equal to zero (0 2)")
 61.         putdocx paragraph
 62.         * Short-run post-treatment tests (0 2)
.         estimates restore es
 63.         cap quietly estat event, window(0 2) post
 64.         if _rc == 0{
 65.                 local coefnames : colnames e(b)
 66.                 local tst ""
 67.                 foreach c of local coefnames {
 68.                         if strpos("`c'", "Tp"){
 69.                                 local tst "`tst' (`c'=0)"
 70.                         }
 71.                     }
 72.                 test `tst'
 73.                 putdocx table srWald = (3, 2)
 74.                 putdocx table srWald(1,1) = ("chi2"), bold
 75.                 putdocx table srWald(1,2) = (strofreal(r(chi2), "$NUMFMT"))
 76.                 putdocx table srWald(2,1) = ("df"), bold
 77.                 putdocx table srWald(2,2) = (string(r(df)))
 78.                 putdocx table srWald(3,1) = ("p"), bold
 79.                 putdocx table srWald(3,2) = (strofreal(r(p), "$NUMFMT"))
 80.         } 
 81.         else {
 82.                 putdocx text ("Test failed, missing/incomplete coefficients for window (0 2)")
 83.         }
 84.         
.         * Medium-run post-treatment tests (3 POSTSHORT)
.         putdocx paragraph
 85.         putdocx text ("H0: all medium-run post-treatment coefficients are equal to zero (3 `postshort')")
 86.         putdocx paragraph
 87.         estimates restore es
 88.         cap quietly estat event, window(3 `postshort') post
 89.         if _rc == 0 {
 90.                 local coefnames : colnames e(b)
 91.                 local tst ""
 92.                 foreach c of local coefnames {
 93.                         if strpos("`c'", "Tp"){
 94.                                 local tst "`tst' (`c'=0)"
 95.                         }
 96.                     }
 97.                 test `tst'
 98.                 putdocx table mrWald = (3, 2)
 99.                 putdocx table mrWald(1,1) = ("chi2"), bold
100.                 putdocx table mrWald(1,2) = (strofreal(r(chi2), "$NUMFMT"))
101.                 putdocx table mrWald(2,1) = ("df"), bold
102.                 putdocx table mrWald(2,2) = (string(r(df)))
103.                 putdocx table mrWald(3,1) = ("p"), bold
104.                 putdocx table mrWald(3,2) = (strofreal(r(p), "$NUMFMT"))
105.         } 
106.         else {
107.                 putdocx text ("Test failed, missing/incomplete coefficients for window (3 `postshort')")
108.         }
109.         
.         * Long-run post-treatment tests (5 `postlong')
.         putdocx paragraph
110.         putdocx text ("H0: all long-run post-treatment coefficients are equal to zero (5 `postlong')")
111.         putdocx paragraph
112.         estimates restore es
113.         cap quietly estat event, window(5 `postlong') post
114.         if _rc == 0 {
115.                 local coefnames : colnames e(b)
116.                 local tst ""
117.                 foreach c of local coefnames {
118.                         if strpos("`c'", "Tp"){
119.                                 local tst "`tst' (`c'=0)"
120.                         }
121.                     }
122.                 test `tst'
123.                 putdocx table lrWald = (3, 2)
124.                 putdocx table lrWald(1,1) = ("chi2"), bold
125.                 putdocx table lrWald(1,2) = (strofreal(r(chi2), "$NUMFMT"))
126.                 putdocx table lrWald(2,1) = ("df"), bold
127.                 putdocx table lrWald(2,2) = (string(r(df)))
128.                 putdocx table lrWald(3,1) = ("p"), bold
129.                 putdocx table lrWald(3,2) = (strofreal(r(p), "$NUMFMT"))
130.         } 
131.         else {
132.                 putdocx text ("Test failed, missing/incomplete coefficients for window (5 `postlong')")
133.         }
134.         
.         * Number of observations (total, per-cohort)
.         count
135.         local N = r(N)
136.         
.         * Mark first est_id in sample
.         bys est_id: gen byte __first = (_n == 1)
137.         count if __first
138.         local E = r(N)
139.         
.         * Number of establishments in treatment group
.         count if __first & first_hit > 0
140.         local E_treated = r(N)
141.         
.         * Number of establishments in comparison group
.         count if __first & first_hit == 0
142.         local E_comp = r(N)
143.         
.         drop __first
144.         
.         putdocx table obs = (4, 2)
145.         putdocx table obs(1,1) = ("N Obs"), bold
146.         putdocx table obs(1,2) = ("`N'")
147.         putdocx table obs(2,1) = ("N Establishments"), bold
148.         putdocx table obs(2,2) = ("`E'")
149.         putdocx table obs(3,1) = ("N Treated Establishments"), bold
150.         putdocx table obs(3,2) = ("`E_treated'")
151.         putdocx table obs(4,1) = ("N Comparison Establishments"), bold
152.         putdocx table obs(4,2) = ("`E_comp'")
153.         
.         putdocx paragraph, style(Heading2)
154.         putdocx text ("Figure saved to: `outpng'")
155.         putdocx save "`outdoc'", replace
156.         
.     restore
157. end

