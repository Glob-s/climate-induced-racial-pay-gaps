. * -----------------------------------------------------------------------------
. * PROGRAM: descriptive statistics (N, Mean, Std.Dev, Min, Max)
. * OPTIONS:
. * vars() - specify varlist as a space-separated list of names e.g. vars("varA varB varC")
. * numvars() - must be equal to number of variables in vars()
. * title() - specify title of document
. * outdoc() - specify full path to save the .docx file
. * -----------------------------------------------------------------------------
. cap program drop _desc_table_docx

. program define _desc_table_docx
  1.     version 18.0
  2.     syntax , VARS(string) NUMVARS(integer) TITLE(string) OUTDOC(string)
  3. 
.     putdocx clear
  4.     putdocx begin, pagesize(letter) font("Times New Roman",10)
  5.     putdocx paragraph, style(Heading1)
  6.     
.     local nrows = `numvars' + 1
  7.     putdocx table table1 = (`nrows', 6)
  8.     
.     putdocx table table1(1,1) = ("Variable"), bold
  9.     putdocx table table1(1,2) = ("Obs"), bold
 10.     putdocx table table1(1,3) = ("Mean"), bold
 11.     putdocx table table1(1,4) = ("Std. Dev"), bold
 12.     putdocx table table1(1,5) = ("Min"), bold
 13.     putdocx table table1(1,6) = ("Max"), bold
 14.     
.     local i = 2
 15.     foreach var of varlist `vars' {
 16.         quietly summarize `var'
 17.         putdocx table table1(`i',1) = ("`var'")
 18.         putdocx table table1(`i',2) = (string(r(N)))
 19.         putdocx table table1(`i',3) = (strofreal(r(mean), "$NUMFMT"))
 20.         putdocx table table1(`i',4) = (strofreal(r(sd), "$NUMFMT"))
 21.         putdocx table table1(`i',5) = (strofreal(r(min), "$NUMFMT"))
 22.         putdocx table table1(`i',6) = (strofreal(r(max), "$NUMFMT"))
 23.         
.         local ++i
 24.     }
 25.     putdocx paragraph
 26.     putdocx text ("Notes: Establishment-year panel. Means and standard deviations computed over the estimation 
> sample. ")
 27.     putdocx save "`outdoc'", replace
 28. end

. 
end of do-file

