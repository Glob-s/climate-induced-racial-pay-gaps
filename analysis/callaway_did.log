 14.     
.     local i = 2
 15.     foreach var of varlist `vars' {
 16.         quietly summarize `var'
 17.         putdocx table table1(`i',1) = ("`var'")
 18.         putdocx table table1(`i',2) = (string(r(N)))
 19.         putdocx table table1(`i',3) = (strofreal(r(mean), "$NUMFMT"))
 20.         putdocx table table1(`i',4) = (strofreal(r(sd), "$NUMFMT"))
 21.         putdocx table table1(`i',5) = (strofreal(r(min), "$NUMFMT"))
 22.         putdocx table table1(`i',6) = (strofreal(r(max), "$NUMFMT"))
 23.         
.         local ++i
 24.     }
 25.     putdocx paragraph
 26.     putdocx text ("Notes: Establishment-year panel. Means and standard deviations computed over the estimation 
> sample. ")
 27.     putdocx save "`outdoc'", replace
 28. end

. 
end of do-file

