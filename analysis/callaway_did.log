. do 00_globals.do

. * 0.1 Install required packages ---------------------------------------------
. cap which csdid

. if _rc ssc install csdid, replace

. cap which event_plot

. if _rc ssc install event_plot, replace

. cap ssc install estout, replace          // for summary table, optional

. ssc install drdid, replace
checking drdid consistency and verifying not already installed...
all files already exist and are up to date.

. 
. * 1. Load data ---------------------------------------------------------------
. import delimited "data/brazil_firms_panel_2003_2017.csv", ///
>         varnames(1) stringcols(1) clear
(encoding automatically selected: ISO-8859-2)
(20 vars, 978,175 obs)

. 
. destring year, replace force
year already numeric; no replace

. 
. * 1.1 Create output directories -----------------------------------------------
. cap mkdir results

. cap mkdir results/tables 

. cap mkdir results/plots 

. 
. * 2. Treatment timing --------------------------------------------------------
. egen first_hit = min(cond(treated==1, year, .)), by(cnpj_cei)
(850,596 missing values generated)

. gen  never_treated = missing(first_hit)

. replace first_hit = 0 if never_treated  // CS&A requires never-treated = 0
(850,596 real changes made)

. 
. * 2.1 Forward-fill first_hit within treated grids ---------------------------
. bysort cnpj_cei (year): replace first_hit = first_hit[1]
(0 real changes made)

. 
. * 2.2 drop observations after a SECOND disaster hits the same est.
. 
. bys cnpj_cei: egen second_hit_year = min(cond(treated==1 & first_hit!=0 & year>first_hit, year, .))
(948,326 missing values generated)

. drop if !missing(second_hit_year) & year >= second_hit_year // keep first-event panel
(13,168 observations deleted)

. order cnpj_cei year first_hit

. 
. * 3. Drop outdated values from master panel
. drop avg_wage_est avg_wage_white avg_wage_nonwhite avg_wage_female avg_wage_male avg_wage_lowereduc avg_wage_highe
> reduc avg_wage_disab avg_wage_nondis

. 
. save "data/panel_estab_year.dta", replace
file data/panel_estab_year.dta saved

. 
end of do-file

